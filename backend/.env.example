APP_ENV=dev
# 可选：memory / postgres；不填时会按是否存在 DATABASE_URL 自动判断
APP_STORAGE_BACKEND=postgres
# PostgreSQL 连接池配置（仅 postgres 模式生效）
APP_DB_POOL_MIN_SIZE=2
APP_DB_POOL_MAX_SIZE=10
# 逗号分隔 CORS 白名单；不填时默认 localhost:5173
APP_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产环境请使用至少 32 字节的随机字符串
JWT_SECRET_KEY=replace-with-a-long-random-secret
# 当前阶段默认共用这一套数据库连接
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/say_right
# LLM 模式：deterministic（默认）/ provider（真实模型）
LLM_MODE=provider
LLM_MODEL=gpt-4o
# provider 模式时必填；deterministic 可留空
LLM_API_KEY=
# 可选：OpenAI-compatible base URL（如网关或代理）
LLM_BASE_URL=
