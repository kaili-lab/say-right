# 迁移期运行模式
APP_ENV=dev
APP_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Better Auth 会话配置
# WHY: Hono 迁移后由 Better Auth 统一负责 session/cookie 鉴权
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:8787

# Cloudflare / D1 配置
# WHAT: wrangler.toml 里绑定 D1，环境变量保留账号与库标识用于部署脚本
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
D1_DATABASE_NAME=say_right

# OpenAI 兼容客户端配置
LLM_MODE=provider
LLM_MODEL=gpt-4o-free
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 迁移兼容字段（后续任务中逐步收敛）
LLM_API_KEY=
LLM_BASE_URL=
